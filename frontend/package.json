    "@types/papaparse": "5.5.2",
    "@vitest/browser-playwright": "4.1.8",
    "angular-eslint": "22.0.0",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.6",
