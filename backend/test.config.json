{
  "$schema": "https://nodejs.org/dist/v26.3.0/docs/node-config-schema.json",
  "nodeOptions": {
    "import": ["tsx"]
  },
  "test": {
    "experimental-test-coverage": true,
    "test-reporter": "spec",
    "test-coverage-exclude": [
      "src/**/*.spec.ts",
      "src/tests/**",
      "src/index.ts",
      "src/web-server/routes.ts",
      "src/web-server/web-server.ts",
      "src/settings-interface.generator.ts",
      "src/migration/**",
      "src/**/manifest.ts",
      "src/model/**",
      "shared/**"
    ]
  }
}
